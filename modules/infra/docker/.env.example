# =============================================================================
# AuditorSEC / DaBROIoTEXs — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# ── Platform ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PLATFORM_PORT=3000
SESSION_SECRET=change-me-in-production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=auditorsec
POSTGRES_PASSWORD=auditorsec
POSTGRES_DB=auditorsec
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MQTT (Mosquitto) ────────────────────────────────────────────────────────
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USER=auditorsec
MQTT_PASSWORD=change-me

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=auditorsec

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── DigitalOcean ─────────────────────────────────────────────────────────────
DIGITALOCEAN_ACCESS_TOKEN=
DIGITALOCEAN_SPACES_KEY=
DIGITALOCEAN_SPACES_SECRET=
