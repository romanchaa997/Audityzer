        [{ "node": "Run Health Checks", "type": "main", "index": 0 }],
        [{ "node": "Fetch KPI", "type": "main", "index": 0 }],
        [{ "node": "Run Health Checks", "type": "main", "index": 0 }],
        [{ "node": "Help Message", "type": "main", "index": 0 }]
