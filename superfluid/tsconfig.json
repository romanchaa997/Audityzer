{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["scripts/**/*.ts", "monitoring/**/*.ts", "config/**/*.ts", "test/**/*.ts", "hardhat.config.ts"],
  "exclude": ["node_modules", "dist", "subgraph"]
}
